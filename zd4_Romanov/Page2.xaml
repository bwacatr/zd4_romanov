<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="zd4_Romanov.Page2"
             Title="Курсы валют">
    <ContentPage.Content>
        <Grid Padding="30, 80" RowSpacing="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="500" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackLayout Grid.Row="0">
                <Label Text="Центробанк РФ" FontSize="Title" HorizontalOptions="CenterAndExpand" HorizontalTextAlignment="Center"/>
            </StackLayout>
            <StackLayout Grid.Row="1">
                <Label x:Name="DollarText" Text="USD" FontSize="Large" HorizontalOptions="CenterAndExpand" HorizontalTextAlignment="Center"/>
                <Label x:Name="EuroText" FontSize="Large" Text="EUR" HorizontalOptions="CenterAndExpand" HorizontalTextAlignment="Center"/>
            </StackLayout>

            <StackLayout Grid.Row="2">
                <Label x:Name="dateText" Text="Текущая дата:" FontSize="Large" HorizontalOptions="CenterAndExpand" HorizontalTextAlignment="Center"/>
                <DatePicker x:Name="DatePickerNow"/>
            </StackLayout>

        </Grid>
    </ContentPage.Content>
</ContentPage>